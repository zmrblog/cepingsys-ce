# =====================================================
# 年度考核测评系统 - 环境配置文件
# 兼容: PHP 8.1 + Laragon 6.0 + Windows Server 2008
# 复制此文件为 .env 并修改相应配置
# =====================================================

# 应用配置
APP_NAME=年度考核测评系统
APP_ENV=production
APP_DEBUG=false
APP_URL=http://test.com:2001

# 数据库配置（适配Laragon环境）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=examine_system
DB_USERNAME=root
DB_PASSWORD=

# 注意: Laragon默认root密码为空，如已修改请填写实际密码

# JWT认证配置
JWT_SECRET=your-secret-key-change-in-production-2026
JWT_EXPIRE_HOURS=24

# 验证码配置
CAPTCHA_ENABLED=true
CAPTCHA_EXPIRE_MINUTES=5

# GeoIP2 IP库路径（国外IP屏蔽）
# 默认使用 api/data/ 目录下的文件，一般无需修改
# IP_FILTER_ENABLED=false
# MMDB_PATH=

# 文件上传配置
UPLOAD_MAX_SIZE=10485760

# 日志配置（默认写入 logs/ 目录，一般无需修改）
# LOG_PATH=
LOG_LEVEL=warning
